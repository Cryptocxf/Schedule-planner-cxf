# 全能出行管家技能配置模板
# 复制此文件为 .env 并填入您的配置

# ========== API Keys ==========

# 高德地图 API Key
# 获取方式：https://lbs.amap.com/
AMAP_API_KEY=your_amap_api_key_here

# 途牛旅行 API Key
# 获取方式：联系途牛开放平台
TUNIU_API_KEY=your_tuniu_api_key_here

# ========== 默认乘客信息 ==========

# 乘客姓名
PASSENGER_NAME=your_name

# 身份证号
PASSENGER_ID=your_id_number

# 手机号
PASSENGER_MOBILE=your_mobile

# ========== 说明 ==========
# 1. 将此文件重命名为 .env
# 2. 填入您的真实 API Keys
# 3. 修改乘客信息为您的默认乘客
# 4. 保存后即可使用
